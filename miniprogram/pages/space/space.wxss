.space-page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(145deg, #eef5e9, #f8faf0);
}

.skin-blue {
  background: linear-gradient(145deg, #eaf4ff, #eef5e9);
}

.skin-green {
  background: linear-gradient(145deg, #e7f7ee, #fbfcf4);
}

.skin-orange {
  background: linear-gradient(145deg, #fff2df, #eaf4ff);
}

.skin-aurora {
  background: linear-gradient(145deg, #e7fff7, #f4edff);
}

.skin-night {
  color: #f5f7f3;
  background: linear-gradient(145deg, #243447, #4b5f72);
}

.profile-card {
  display: grid;
  grid-template-columns: 128rpx 1fr auto;
  align-items: center;
  gap: 22rpx;
  padding: 24rpx;
}

.avatar-wrap {
  width: 128rpx;
  height: 128rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: rgba(47, 95, 80, 0.12);
}

.avatar {
  width: 128rpx;
  height: 128rpx;
}

.placeholder {
  color: #2f5f50;
  font-size: 56rpx;
  font-weight: 800;
  line-height: 128rpx;
  text-align: center;
}

.identity {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 10rpx;
}

.nickname {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
}

.rank {
  color: #2f5f50;
  font-size: 24rpx;
}

.motto {
  display: block;
  color: #6f766f;
  font-size: 26rpx;
}

.profile-more {
  align-self: center;
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  color: #2f5f50;
  background: rgba(47, 95, 80, 0.1);
  font-size: 24rpx;
  font-weight: 700;
}

.quick-row,
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.stats-grid {
  grid-template-columns: repeat(2, 1fr);
}

.stat {
  min-height: 112rpx;
  padding: 18rpx 12rpx;
}

.stat-num {
  display: block;
  overflow: hidden;
  font-size: 30rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  color: #6f766f;
  font-size: 22rpx;
}

.checkin,
.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 22rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
}

.section-copy {
  display: block;
  margin-top: 8rpx;
  color: #6f766f;
  font-size: 22rpx;
  line-height: 1.5;
}

.mini {
  min-width: 148rpx;
  min-height: 62rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
}

.tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 22rpx;
}

.tab {
  height: 72rpx;
  border-radius: 8rpx;
  color: #5f6962;
  background: rgba(255, 255, 255, 0.64);
  font-size: 26rpx;
}

.tab.active {
  color: #ffffff;
  background: #2f5f50;
}

.panel {
  margin-top: 18rpx;
}

.skin-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.skin-card {
  padding: 16rpx;
}

.skin-card.selected {
  border-color: #2f5f50;
}

.skin-preview {
  height: 126rpx;
  border-radius: 8rpx;
  background: linear-gradient(145deg, #eef5e9, #f8faf0);
}

.tone-blue {
  background: linear-gradient(145deg, #eaf4ff, #8bb9df);
}

.tone-green {
  background: linear-gradient(145deg, #e7f7ee, #8bc7a8);
}

.tone-orange {
  background: linear-gradient(145deg, #fff2df, #e7a256);
}

.tone-aurora {
  background: linear-gradient(145deg, #e7fff7, #b69ae5);
}

.tone-night {
  background: linear-gradient(145deg, #243447, #6b88a1);
}

.skin-name {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.skin-rarity {
  display: block;
  margin: 8rpx 0 14rpx;
  color: #6f766f;
  font-size: 22rpx;
}

.records {
  margin-top: 18rpx;
  padding: 22rpx;
}

.empty {
  padding: 36rpx 0;
  color: #7a827b;
  font-size: 26rpx;
  text-align: center;
}

.record {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(61, 85, 73, 0.1);
}

.record-title,
.record-copy,
.record-reward {
  display: block;
}

.record-title {
  font-size: 26rpx;
  font-weight: 700;
}

.record-copy,
.record-reward {
  margin-top: 8rpx;
  color: #6f766f;
  font-size: 22rpx;
}

.record-reward {
  max-width: 260rpx;
  text-align: right;
}

.modal-mask {
  position: fixed;
  z-index: 20;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(31, 39, 35, 0.42);
}

.result-card {
  position: relative;
  display: flex;
  width: 100%;
  max-width: 640rpx;
  flex-direction: column;
  gap: 22rpx;
  padding: 58rpx 32rpx 32rpx;
  color: #27312d;
  text-align: center;
}

.mascot {
  position: absolute;
  top: -38rpx;
  left: 50%;
  width: 86rpx;
  height: 86rpx;
  transform: translateX(-50%);
  border-radius: 50%;
  color: #ffffff;
  background: #2f5f50;
  font-size: 44rpx;
  line-height: 86rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: 800;
}

.result-copy {
  color: #5f6962;
  font-size: 28rpx;
  line-height: 1.65;
}

.reward-chip {
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  color: #2f5f50;
  background: rgba(47, 95, 80, 0.1);
  font-size: 22rpx;
}
