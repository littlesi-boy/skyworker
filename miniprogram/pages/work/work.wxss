  0% {
    opacity: 0;
    transform: translate3d(-50%, 28rpx, 0) scale(0.76) rotate(-8deg);
  }
  16% {
    opacity: 1;
  }
  40% {
    opacity: 1;
    transform: translate3d(-50%, -82rpx, 0) scale(1.12) rotate(3deg);
  }
  100% {
    opacity: 0;
    transform: translate3d(-50%, -176rpx, 0) scale(1.18) rotate(-2deg);
  }
}

@keyframes frostBreath {
  0% {
    opacity: .82;
    filter: saturate(1);
  }
  100% {
    opacity: .96;
    filter: saturate(1.18);
  }
}

@keyframes snowSpin {
  0% {
    transform: rotate(0deg) scale(.94);
  }
  50% {
    transform: rotate(180deg) scale(1.08);
  }
  100% {
    transform: rotate(360deg) scale(.94);
  }
}

@keyframes frostToast {
  0% {
    opacity: 0;
    transform: translateX(-50%) translateY(-24rpx) scale(.96);
  }
  16%, 78% {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateX(-50%) translateY(-10rpx) scale(.98);
  }
}

.fail-slam.progress {
