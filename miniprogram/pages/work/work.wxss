@keyframes robotHover {
  0% {
    transform: translate3d(0, 0, 0) rotate(-2deg);
  }
  100% {
    transform: translate3d(0, -13rpx, 0) rotate(2deg);
  }
}

@keyframes robotEyePulseA {
  0%, 100% {
    transform: scaleY(.62);
  }
  42% {
    transform: scaleY(1.08);
  }
  70% {
    transform: scaleY(.78);
  }
}

@keyframes robotEyePulseB {
  0%, 100% {
    transform: scaleY(1);
  }
  38% {
    transform: scaleY(.58);
  }
  72% {
    transform: scaleY(1.16);
  }
}

