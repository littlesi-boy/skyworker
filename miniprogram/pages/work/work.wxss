}

@keyframes pop {
  from {
    transform: translateX(-50%) translateY(0);
  }
  to {
    transform: translateX(-50%) translateY(-10rpx);
  }
}

@keyframes runnerBounce {
  from {
    transform: translateX(-50%) translateY(0) rotate(-1deg);
  }
  to {
    transform: translateX(-50%) translateY(-16rpx) rotate(1deg);
  }
}

@keyframes headNod {
  from {
    transform: rotate(-3deg);
  }
  to {
    transform: rotate(4deg);
  }
}

@keyframes hairWobble {
  from {
    margin-top: 0;
  }
  to {
    margin-top: -6rpx;
  }
}

@keyframes armFront {
  from {
    transform: rotate(-58deg);
  }
  to {
    transform: rotate(-26deg);
  }
}

@keyframes armBack {
  from {
    transform: rotate(24deg);
  }
  to {
    transform: rotate(60deg);
  }
}

@keyframes legFront {
  from {
    transform: rotate(-38deg);
  }
  to {
    transform: rotate(-10deg);
  }
}

@keyframes legBack {
  from {
    transform: rotate(38deg);
  }
  to {
    transform: rotate(12deg);
  }
}

@keyframes buttonPulse {
  from {
    transform: translateY(0);
  }
  to {
    transform: translateY(-7rpx);
  }
}

@keyframes cloudFloat {
  from {
    margin-left: 0;
  }
  to {
    margin-left: 24rpx;
  }
}

@keyframes loadShine {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(760rpx);
  }
}

@keyframes heartBoil {
  0% {
    transform: rotate(-45deg) translate3d(0, 0, 0) scale(.82);
    opacity: .18;
  }
  45% {
    opacity: .82;
  }
  100% {
    transform: rotate(-15deg) translate3d(-18rpx, -230rpx, 0) scale(1.08);
    opacity: .12;
  }
}

@keyframes bubbleRise {
  0% {
    transform: translateY(0) scale(.75);
    opacity: 0;
  }
  30% {
    opacity: .76;
  }
  100% {
    transform: translateY(-250rpx) scale(1.25);
    opacity: 0;
  }
}

@keyframes heartBeat {
  0%, 100% {
    transform: rotate(-45deg) scale(1);
  }
  50% {
    transform: rotate(-45deg) scale(1.08);
  }
}

@keyframes codeDrift {
  from {
    transform: translateY(0);
    opacity: .2;
  }
  50% {
    opacity: .75;
  }
  to {
    transform: translateY(28rpx);
    opacity: .2;
  }
}

@keyframes scanScreen {
  from {
    top: -40rpx;
  }
  to {
    top: 360rpx;
  }
}

@keyframes slamIn {
  0% {
    opacity: 0;
    transform: scale(1.08);
  }
  18% {
    opacity: 1;
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes slamText {
  0% {
    transform: scale(2.2) rotate(-8deg);
    opacity: 0;
  }
  100% {
    transform: scale(1) rotate(-3deg);
    opacity: 1;
  }
}
