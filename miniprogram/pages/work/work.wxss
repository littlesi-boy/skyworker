.work-page {
  position: relative;
  min-height: 100vh;
  padding: calc(88rpx + env(safe-area-inset-top)) 24rpx 24rpx;
  overflow: hidden;
  background: linear-gradient(145deg, #eef5e9, #f8faf0);
}

.skin-blue {
  background: linear-gradient(145deg, #eaf4ff, #eef5e9);
}

.skin-green {
  background: linear-gradient(145deg, #e7f7ee, #fbfcf4);
}

.skin-orange {
  background: linear-gradient(145deg, #fff2df, #eaf4ff);
}

.skin-aurora {
  background: linear-gradient(145deg, #e7fff7, #f4edff);
}

.skin-night {
  color: #f5f7f3;
  background: linear-gradient(145deg, #243447, #4b5f72);
}

.topbar {
  display: grid;
  grid-template-columns: 1fr 108rpx;
  gap: 18rpx;
  align-items: center;
  min-height: 92rpx;
  padding: 18rpx 18rpx 14rpx;
  border: 1rpx solid rgba(61, 85, 73, 0.12);
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.62);
  box-shadow: 0 10rpx 28rpx rgba(33, 50, 42, 0.06);
}

.rank-block {
  display: flex;
  min-width: 0;
  flex-direction: column;
}

.rank-title {
  display: block;
  overflow: hidden;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 42rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-tier {
  margin-top: 6rpx;
  color: #6f766f;
  font-size: 22rpx;
}

.timer {
  height: 72rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #2f5f50;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 72rpx;
  text-align: center;
}

.locked {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 120rpx;
  padding: 36rpx;
}

.locked-title {
  font-size: 38rpx;
  font-weight: 700;
}

.locked-copy {
  color: #6f766f;
  font-size: 28rpx;
  line-height: 1.7;
}

.game-shell {
  position: relative;
  min-height: calc(100vh - 160rpx);
}

.guide {
  position: absolute;
  top: 26rpx;
  left: 50%;
  z-index: 4;
  width: 560rpx;
  max-width: calc(100vw - 64rpx);
  padding: 16rpx 20rpx;
  transform: translateX(-50%);
  border-radius: 8rpx;
  color: #415349;
  background: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  text-align: center;
}

.meters {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  min-height: 760rpx;
  padding-top: 34rpx;
}

.meter-zone {
  display: flex;
  align-items: center;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
  min-height: 744rpx;
  padding: 18rpx 8rpx 20rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(61, 85, 73, 0.1);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(234, 244, 236, 0.34));
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7), 0 16rpx 32rpx rgba(33, 50, 42, 0.06);
}

.dev-device,
.mood-device {
  position: relative;
  width: 298rpx;
  height: 500rpx;
}

.machine-tag {
  height: 42rpx;
  margin-bottom: 16rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  color: #e8fff1;
  background: #26342e;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 42rpx;
  letter-spacing: 0;
  box-shadow: 0 8rpx 0 rgba(38, 52, 46, 0.24);
}

.mood-tag {
  color: #fff4f6;
  background: #7e4152;
}

.dev-device {
  display: flex;
  align-items: center;
  flex-direction: column;
  justify-content: flex-start;
  padding-top: 48rpx;
}

.device-top {
  display: none;
  align-items: center;
  width: 286rpx;
  height: 46rpx;
  padding: 0 14rpx;
  border-radius: 18rpx 18rpx 0 0;
  background: #26342e;
  box-shadow: inset 0 -4rpx 0 rgba(0, 0, 0, 0.16);
}

.dot {
  width: 12rpx;
  height: 12rpx;
  margin-right: 8rpx;
  border-radius: 50%;
}

.dot.red {
  background: #e46c62;
}

.dot.yellow {
  background: #f3c766;
}

.dot.green {
  background: #70c58c;
}

.terminal-title {
  display: none;
}

.code-screen {
  position: relative;
  width: 286rpx;
  height: 368rpx;
  overflow: hidden;
  border: 12rpx solid #26342e;
  border-radius: 26rpx;
  background: #101815;
  box-shadow: inset 0 0 40rpx rgba(0, 0, 0, 0.45), 0 24rpx 36rpx rgba(36, 52, 45, 0.2);
}

.code-fill {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 20rpx;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(34, 113, 71, 0.22), rgba(54, 210, 118, 0.58));
  box-shadow: 0 -18rpx 34rpx rgba(54, 210, 118, 0.18);
  transition: height 0.16s linear;
}

.code-line {
  display: block;
  width: 100%;
  height: 18rpx;
  border-radius: 6rpx;
  color: #b9ffd0;
  background: rgba(142, 255, 185, 0.2);
  font-family: Menlo, Consolas, monospace;
  font-size: 14rpx;
  line-height: 18rpx;
  text-shadow: 0 0 10rpx rgba(88, 255, 145, 0.5);
}

.code-rain {
  position: absolute;
  color: rgba(173, 255, 202, 0.44);
  font-family: Menlo, Consolas, monospace;
  font-size: 18rpx;
  line-height: 1;
  animation: codeDrift 2.2s linear infinite;
}

.rain-a {
  top: 24rpx;
  left: 22rpx;
}

.rain-b {
  top: 90rpx;
  right: 26rpx;
  animation-delay: .4s;
}

.rain-c {
  bottom: 34rpx;
  left: 38rpx;
  animation-delay: .8s;
}

.scan-line {
  position: absolute;
  right: 0;
  left: 0;
  z-index: 3;
  height: 36rpx;
  background: linear-gradient(180deg, transparent, rgba(122, 255, 164, 0.18), transparent);
  animation: scanScreen 2.6s linear infinite;
}

.code-line.short {
  width: 72%;
}

.code-line.dim {
  opacity: 0.62;
}

.screen-glare {
  position: absolute;
  top: -50rpx;
  right: 24rpx;
  width: 60rpx;
  height: 410rpx;
  transform: rotate(14deg);
  background: rgba(255, 255, 255, 0.06);
}

.device-line {
  bottom: 40%;
}

.mood-device {
  display: flex;
  align-items: center;
  flex-direction: column;
}

.pressure-gauge {
  position: relative;
  width: 250rpx;
  height: 30rpx;
  margin-bottom: 18rpx;
  overflow: hidden;
  border: 4rpx solid rgba(126, 65, 82, 0.24);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.58);
}

.gauge-bar {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  border-radius: 30rpx;
  background: linear-gradient(90deg, #bf7d83, #e84d75);
  transition: width .16s linear;
}

.mood-high .gauge-bar {
  background: linear-gradient(90deg, #f28ca4, #e84d75);
}

.mood-mid .gauge-bar {
  background: linear-gradient(90deg, #d9a16d, #d9828f);
}

.mood-low .gauge-bar,
.mood-empty .gauge-bar {
  background: linear-gradient(90deg, #b7a1a1, #bf7d83);
}

.gauge-dot {
  position: absolute;
  top: 7rpx;
  left: 14rpx;
  z-index: 2;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #ffffff;
}

.mood-glass {
  position: relative;
  width: 242rpx;
  height: 368rpx;
  overflow: hidden;
  border: 10rpx solid rgba(126, 65, 82, 0.34);
  border-radius: 120rpx 120rpx 50rpx 50rpx;
  background: radial-gradient(circle at 50% 32%, rgba(255,255,255,.92), rgba(255, 226, 232, 0.6) 46%, rgba(255, 203, 213, 0.42));
  box-shadow: inset 0 0 34rpx rgba(255, 255, 255, 0.95), inset 0 -30rpx 44rpx rgba(232, 77, 117, 0.1), 0 24rpx 36rpx rgba(126, 65, 82, 0.14);
}

.heart-stack {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(255, 160, 180, 0.28), rgba(224, 68, 99, 0.5));
  box-shadow: 0 -18rpx 32rpx rgba(232, 77, 117, 0.12);
  transition: height 0.16s linear, opacity 0.16s linear;
}

.mood-low .heart-stack {
  opacity: 0.48;
  background: linear-gradient(180deg, rgba(255, 198, 202, 0.12), rgba(183, 99, 99, 0.26));
}

.mood-mid .heart-stack {
  opacity: 0.74;
}

.mood-empty .heart-stack {
  opacity: 0.18;
}

.heart-bubble {
  position: absolute;
  right: 40rpx;
  bottom: 18rpx;
  width: 30rpx;
  height: 28rpx;
  transform: rotate(-45deg);
  background: #ec4c7a;
  opacity: .76;
  animation: heartBoil 2.4s ease-in-out infinite;
}

.heart-bubble::before,
.heart-bubble::after,
.heart-shape::before,
.heart-shape::after {
  position: absolute;
  content: "";
  border-radius: 50%;
  background: inherit;
}

.heart-bubble::before,
.heart-shape::before {
  top: -50%;
  left: 0;
  width: 100%;
  height: 100%;
}

.heart-bubble::after,
.heart-shape::after {
  top: 0;
  right: -50%;
  width: 100%;
  height: 100%;
}

.heart-a { right: 28rpx; animation-delay: 0s; }
.heart-b { right: 72rpx; width: 24rpx; height: 22rpx; animation-delay: .22s; }
.heart-c { right: 124rpx; width: 34rpx; height: 31rpx; animation-delay: .48s; }
.heart-d { right: 164rpx; width: 22rpx; height: 20rpx; animation-delay: .76s; }
.heart-e { right: 48rpx; width: 20rpx; height: 18rpx; animation-delay: 1s; }
.heart-f { right: 102rpx; width: 28rpx; height: 26rpx; animation-delay: 1.28s; }
.heart-g { right: 150rpx; width: 26rpx; height: 24rpx; animation-delay: 1.52s; }
.heart-h { right: 88rpx; width: 18rpx; height: 16rpx; animation-delay: 1.78s; }

.mood-bubble {
  position: absolute;
  bottom: 12rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255,255,255,.42);
  animation: bubbleRise 2.1s ease-in infinite;
}

.bubble-a { right: 34rpx; animation-delay: .1s; }
.bubble-b { right: 82rpx; width: 7rpx; height: 7rpx; animation-delay: .58s; }
.bubble-c { right: 132rpx; width: 12rpx; height: 12rpx; animation-delay: .92s; }
.bubble-d { right: 176rpx; width: 8rpx; height: 8rpx; animation-delay: 1.34s; }

.main-heart {
  position: absolute;
  top: 126rpx;
  left: 50%;
  width: 94rpx;
  height: 88rpx;
  transform: translateX(-50%) scale(.72);
}

.heart-shape {
  position: absolute;
  top: 26rpx;
  left: 28rpx;
  width: 82rpx;
  height: 78rpx;
  transform: rotate(-45deg);
  background: #ec4c7a;
  box-shadow: 0 10rpx 24rpx rgba(216, 64, 96, 0.24);
  animation: heartBeat 1.4s ease-in-out infinite;
}

.mood-low .heart-shape,
.mood-low .heart-bubble {
  background: #bf7d83;
}

.mood-empty .heart-shape,
.mood-empty .heart-bubble {
  background: #a6a6a6;
}

.heart-eye {
  position: absolute;
  z-index: 3;
  top: 52rpx;
  width: 14rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: inset -3rpx -3rpx 0 rgba(236, 76, 122, 0.26);
}

.left-eye {
  left: 42rpx;
}

.right-eye {
  right: 42rpx;
}

.heart-mouth {
  position: absolute;
  z-index: 3;
  top: 72rpx;
  left: 50%;
  width: 36rpx;
  height: 20rpx;
  transform: translateX(-50%);
  border-bottom: 6rpx solid #ffffff;
  border-radius: 0 0 30rpx 30rpx;
}

.heart-mouth::before,
.heart-mouth::after {
  position: absolute;
  top: -4rpx;
  width: 16rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255, 183, 199, 0.62);
  content: "";
}

.heart-mouth::before {
  left: -34rpx;
}

.heart-mouth::after {
  right: -34rpx;
}

.mood-low .heart-mouth,
.mood-empty .heart-mouth {
  top: 76rpx;
  border-top: 5rpx solid #ffffff;
  border-bottom: 0;
  border-radius: 30rpx 30rpx 0 0;
}

.mood-mid .heart-mouth {
  width: 28rpx;
  height: 4rpx;
  border: 0;
  border-radius: 4rpx;
  background: #ffffff;
}

.mood-mark {
  position: absolute;
  top: 42rpx;
  width: 22rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.42);
}

.mood-mark.left {
  left: 34rpx;
}

.mood-mark.right {
  right: 34rpx;
}

.mood-line {
  bottom: 40%;
}

.mood-label {
  width: 154rpx;
  height: 42rpx;
  margin-top: 14rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #9d5262;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 42rpx;
  text-align: center;
  box-shadow: 0 10rpx 20rpx rgba(157, 82, 98, 0.18);
}

.mood-fill {
  display: none;
}

.pass-line,
.perfect-line {
  position: absolute;
  right: 0;
  left: 0;
  height: 2rpx;
  background: rgba(39, 49, 45, 0.45);
}

.pass-line {
  bottom: 0;
}

.perfect-line {
  bottom: 40%;
  background: rgba(47, 95, 80, 0.6);
}

.meter-value {
  margin-top: 24rpx;
  font-size: 42rpx;
  font-weight: 800;
}

.meter-title {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.meter-note {
  margin-top: 8rpx;
  color: #7a827b;
  font-size: 20rpx;
  text-align: center;
}

.event-toast {
  position: fixed;
  top: calc(170rpx + env(safe-area-inset-top));
  left: 50%;
  z-index: 6;
  display: flex;
  width: 520rpx;
  flex-direction: column;
  gap: 6rpx;
  padding: 18rpx 24rpx;
  transform: translateX(-50%);
  border-radius: 8rpx;
  color: #ffffff;
  background: rgba(45, 57, 52, 0.9);
  font-size: 24rpx;
}

.event-title {
  font-size: 28rpx;
  font-weight: 700;
}

.overtime-pop {
  position: fixed;
  top: calc(180rpx + env(safe-area-inset-top));
  right: 18rpx;
  z-index: 8;
  display: flex;
  width: 330rpx;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx;
  color: #27312d;
}

.overtime-title {
  font-size: 26rpx;
  font-weight: 700;
}

.overtime-desc {
  color: #5f6962;
  font-size: 22rpx;
  line-height: 1.55;
}

.tiny {
  min-height: 58rpx;
  padding: 0 12rpx;
  font-size: 20rpx;
}

.workspace {
  margin-top: 12rpx;
  padding: 18rpx;
}

.desk-scene {
  position: relative;
  height: 176rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: rgba(47, 95, 80, 0.1);
}

.monitor {
  position: absolute;
  bottom: 52rpx;
  left: 50%;
  width: 180rpx;
  height: 86rpx;
  padding: 16rpx;
  transform: translateX(-50%);
  border: 8rpx solid rgba(39, 49, 45, 0.75);
  border-radius: 6rpx;
  background: rgba(242, 248, 239, 0.95);
}

.screen-line {
  height: 8rpx;
  margin-bottom: 10rpx;
  border-radius: 8rpx;
  background: #6fa68e;
}

.screen-line.short {
  width: 70%;
}

.screen-line.dim {
  opacity: 0.45;
}

.desk {
  position: absolute;
  right: 70rpx;
  bottom: 38rpx;
  left: 70rpx;
  height: 18rpx;
  border-radius: 8rpx;
  background: #8e7560;
}

.badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #2f5f50;
  font-size: 20rpx;
}

.game-control {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 190rpx;
  height: 74rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 8rpx;
  color: #ffffff;
  background: linear-gradient(180deg, #4d8c6e, #2f5f50);
  box-shadow: 0 12rpx 0 #21483d, 0 18rpx 24rpx rgba(33, 72, 61, 0.2);
}

.game-control.playing {
  background: linear-gradient(180deg, #c76d70, #8f3a3a);
  box-shadow: 0 12rpx 0 #6f2c2c, 0 18rpx 24rpx rgba(111, 44, 44, 0.2);
}

.control-icon {
  margin-right: 10rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.control-text {
  font-size: 24rpx;
  font-weight: 900;
}

.workspace-title {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.workspace-desc {
  display: block;
  margin-top: 8rpx;
  color: #6f766f;
  font-size: 22rpx;
  line-height: 1.5;
}

.item-dock {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  justify-content: center;
  gap: 12rpx;
  margin-top: 14rpx;
}

.item-btn {
  position: relative;
  min-width: 0;
  height: 94rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.75);
}

.item-icon {
  display: block;
  font-size: 28rpx;
  line-height: 36rpx;
}

.item-count {
  display: block;
  color: #5f6962;
  font-size: 20rpx;
  line-height: 24rpx;
}

.item-name {
  display: block;
  color: #7a827b;
  font-size: 18rpx;
  line-height: 24rpx;
}

.modal-mask {
  position: fixed;
  z-index: 20;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(31, 39, 35, 0.42);
}

.fail-slam {
  position: fixed;
  z-index: 18;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  color: #ffffff;
  background: rgba(34, 20, 24, 0.78);
  animation: slamIn 0.9s ease-out both;
}

.fail-slam.progress {
  background: rgba(16, 29, 28, 0.82);
}

.slam-line {
  position: absolute;
  top: 50%;
  left: -10%;
  width: 120%;
  height: 148rpx;
  transform: rotate(-6deg);
  background: rgba(190, 48, 66, 0.86);
  box-shadow: 0 0 36rpx rgba(255, 255, 255, 0.18);
}

.fail-slam.progress .slam-line {
  background: rgba(30, 118, 85, 0.88);
}

.slam-title {
  z-index: 2;
  max-width: 680rpx;
  padding: 0 34rpx;
  font-size: 50rpx;
  font-weight: 900;
  line-height: 1.18;
  text-align: center;
  text-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.22);
  animation: slamText 0.55s cubic-bezier(.2, 1.5, .34, 1) both;
}

.slam-copy {
  z-index: 2;
  margin-top: 34rpx;
  font-size: 26rpx;
  opacity: 0.86;
}

.result-card {
  position: relative;
  display: flex;
  width: 100%;
  max-width: 640rpx;
  flex-direction: column;
  gap: 22rpx;
  padding: 58rpx 32rpx 32rpx;
  color: #27312d;
  text-align: center;
}

.result-card.success {
  border-color: rgba(47, 95, 80, 0.24);
}

.result-card.fail {
  border-color: rgba(143, 58, 58, 0.24);
}

.mascot {
  position: absolute;
  top: -38rpx;
  left: 50%;
  width: 86rpx;
  height: 86rpx;
  transform: translateX(-50%);
  border-radius: 50%;
  color: #ffffff;
  background: #2f5f50;
  font-size: 44rpx;
  line-height: 86rpx;
  animation: pop 0.9s ease-in-out infinite alternate;
}

.result-title {
  font-size: 40rpx;
  font-weight: 800;
}

.result-copy {
  color: #5f6962;
  font-size: 28rpx;
  line-height: 1.65;
}

.reward-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
}

.reward-chip {
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  color: #2f5f50;
  background: rgba(47, 95, 80, 0.1);
  font-size: 22rpx;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

@keyframes pop {
  from {
    transform: translateX(-50%) translateY(0);
  }
  to {
    transform: translateX(-50%) translateY(-10rpx);
  }
}

@keyframes heartBoil {
  0% {
    transform: rotate(-45deg) translate3d(0, 0, 0) scale(.82);
    opacity: .18;
  }
  45% {
    opacity: .82;
  }
  100% {
    transform: rotate(-15deg) translate3d(-18rpx, -230rpx, 0) scale(1.08);
    opacity: .12;
  }
}

@keyframes bubbleRise {
  0% {
    transform: translateY(0) scale(.75);
    opacity: 0;
  }
  30% {
    opacity: .76;
  }
  100% {
    transform: translateY(-250rpx) scale(1.25);
    opacity: 0;
  }
}

@keyframes heartBeat {
  0%, 100% {
    transform: rotate(-45deg) scale(1);
  }
  50% {
    transform: rotate(-45deg) scale(1.08);
  }
}

@keyframes codeDrift {
  from {
    transform: translateY(0);
    opacity: .2;
  }
  50% {
    opacity: .75;
  }
  to {
    transform: translateY(28rpx);
    opacity: .2;
  }
}

@keyframes scanScreen {
  from {
    top: -40rpx;
  }
  to {
    top: 360rpx;
  }
}

@keyframes slamIn {
  0% {
    opacity: 0;
    transform: scale(1.08);
  }
  18% {
    opacity: 1;
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes slamText {
  0% {
    transform: scale(2.2) rotate(-8deg);
    opacity: 0;
  }
  100% {
    transform: scale(1) rotate(-3deg);
    opacity: 1;
  }
}
