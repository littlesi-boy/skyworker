.work-page {
  position: relative;
  min-height: 100vh;
  padding: calc(88rpx + env(safe-area-inset-top)) 24rpx 24rpx;
  overflow: hidden;
  background: linear-gradient(145deg, #eef5e9, #f8faf0);
}

.work-page.home-active {
  padding: 0;
  background: #b9f37d;
}

.welcome-toast {
  position: fixed;
  z-index: 60;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  color: #ffffff;
  background: rgba(16, 29, 28, 0.36);
  pointer-events: none;
  animation: welcomeToastIn 3.2s ease-out both;
}

.welcome-band {
  position: absolute;
  left: -10%;
  width: 120%;
  height: 156rpx;
  transform: rotate(-5deg);
  background: linear-gradient(90deg, rgba(31, 98, 74, 0.94), rgba(47, 132, 92, 0.94), rgba(40, 88, 76, 0.94));
  box-shadow: 0 0 36rpx rgba(255, 255, 255, 0.18), inset 0 0 0 3rpx rgba(126, 255, 176, 0.18);
}

.welcome-copy {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  flex-direction: column;
  max-width: 680rpx;
  padding: 0 34rpx;
  text-align: center;
  text-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.18);
  animation: welcomeTextPop 0.55s cubic-bezier(.2, 1.5, .34, 1) both;
}

.welcome-mark {
  color: #ffe66d;
  font-size: 34rpx;
  line-height: 1;
  text-shadow: 0 0 22rpx rgba(255, 230, 109, 0.62);
}

.welcome-title {
  margin-top: 10rpx;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.12;
}

.welcome-text {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.28;
  opacity: .9;
}

.home-scene {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #0b0f0d;
  background: #b9f37d;
}

.sun-panel {
  position: relative;
  z-index: 2;
  display: flex;
  min-height: 262rpx;
  flex-direction: column;
  justify-content: center;
  padding: calc(26rpx + env(safe-area-inset-top)) 54rpx 44rpx;
  background: linear-gradient(180deg, #ffe94a 0%, #ffed57 72%, #fbe96a 100%);
  clip-path: polygon(0 0, 100% 0, 100% 82%, 84% 100%, 50% 76%, 17% 100%, 0 82%);
  text-align: center;
}

.home-title {
  display: block;
  font-size: 76rpx;
  font-weight: 900;
  line-height: .98;
  letter-spacing: 0;
  text-shadow: 0 5rpx 0 rgba(255, 255, 255, 0.18);
}

.home-title.sub {
  margin-top: 28rpx;
}

.sky-panel {
  position: relative;
  height: 582rpx;
  margin-top: -4rpx;
  overflow: hidden;
  background: radial-gradient(circle at 70% 20%, rgba(255, 255, 255, 0.26), transparent 18%), linear-gradient(180deg, #71d7e6, #82ece8 78%, #fdf6ec 100%);
}

.cloud,
.grass {
  position: absolute;
  border: 5rpx solid rgba(34, 113, 71, 0.36);
  border-right: 0;
  border-bottom: 0;
}

.cloud {
  width: 48rpx;
  height: 28rpx;
  border-color: rgba(255, 255, 255, 0.72);
  border-radius: 40rpx 0 0 0;
  opacity: .65;
  animation: cloudFloat 5s ease-in-out infinite alternate;
}

.cloud-a {
  top: 84rpx;
  left: 94rpx;
}

.cloud-b {
  top: 178rpx;
  right: 118rpx;
  transform: scale(.8);
  animation-delay: .7s;
}

.grass {
  width: 34rpx;
  height: 38rpx;
  border-radius: 28rpx 0 0 0;
  opacity: .58;
}

.grass::before,
.grass::after {
  position: absolute;
  bottom: -2rpx;
  width: 26rpx;
  height: 30rpx;
  border: 5rpx solid rgba(34, 113, 71, 0.36);
  border-right: 0;
  border-bottom: 0;
  border-radius: 24rpx 0 0 0;
  content: "";
}

.grass::before {
  left: -16rpx;
  transform: rotate(-26deg);
}

.grass::after {
  right: -16rpx;
  transform: rotate(24deg);
}

.grass-a {
  top: 116rpx;
  left: 118rpx;
}

.grass-b {
  top: 76rpx;
  right: 154rpx;
  transform: scale(.72);
}

.grass-c {
  right: 62rpx;
  bottom: 70rpx;
  transform: scale(.8);
}

.rope-label {
  position: absolute;
  top: 314rpx;
  z-index: 5;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
  text-shadow: -4rpx 0 #111, 0 4rpx #111, 4rpx 0 #111, 0 -4rpx #111, 5rpx 7rpx 0 rgba(0, 0, 0, 0.22);
}

.work-label {
  left: 48rpx;
}

.life-label {
  right: 48rpx;
}

.balance-rope {
  position: absolute;
  left: 138rpx;
  z-index: 4;
  width: 516rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #060606;
  transform-origin: center;
  box-shadow: 0 3rpx 0 rgba(255, 255, 255, 0.18);
}

.rope-one {
  top: 418rpx;
  transform: rotate(14deg);
}

.rope-two {
  top: 421rpx;
  transform: rotate(-14deg);
}

.rope-pin {
  position: absolute;
  z-index: 3;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: rgba(255, 102, 103, 0.55);
}

.pin-left {
  top: 430rpx;
  left: 126rpx;
}

.pin-right {
  top: 430rpx;
  right: 124rpx;
}

.runner {
  position: absolute;
  top: 172rpx;
  left: 50%;
  z-index: 8;
  width: 228rpx;
  height: 286rpx;
  transform: translateX(-50%);
  animation: runnerBounce .74s ease-in-out infinite alternate;
}

.head {
  position: absolute;
  top: 0;
  left: 58rpx;
  width: 120rpx;
  height: 104rpx;
  transform-origin: 55% 100%;
  animation: headNod .74s ease-in-out infinite alternate;
}

.face {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 102rpx;
  height: 82rpx;
  border: 6rpx solid #090909;
  border-radius: 48% 45% 48% 44%;
  background: #ffd8aa;
}

.ear {
  position: absolute;
  bottom: 24rpx;
  left: 6rpx;
  width: 30rpx;
  height: 34rpx;
  border: 6rpx solid #090909;
  border-radius: 50%;
  background: #ffd8aa;
}

.hair {
  position: absolute;
  z-index: 10;
  background: #050505;
  animation: hairWobble .74s ease-in-out infinite alternate;
}

.tuft-a {
  top: -6rpx;
  left: 72rpx;
  width: 96rpx;
  height: 56rpx;
  border-radius: 80rpx 48rpx 36rpx 28rpx;
  transform: rotate(-8deg);
}

.tuft-b {
  top: 10rpx;
  left: 48rpx;
  width: 80rpx;
  height: 70rpx;
  border-radius: 58rpx 44rpx 36rpx 34rpx;
}

.eye-glass {
  position: absolute;
  top: 31rpx;
  width: 34rpx;
  height: 34rpx;
  border: 5rpx solid #090909;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.4);
}

.eye-glass::after {
  position: absolute;
  top: 8rpx;
  left: 11rpx;
  width: 8rpx;
  height: 13rpx;
  border-radius: 50%;
  background: #080808;
  content: "";
}

.eye-glass.left {
  left: 18rpx;
}

.eye-glass.right {
  right: 12rpx;
}

.bridge {
  position: absolute;
  top: 47rpx;
  left: 53rpx;
  width: 18rpx;
  height: 5rpx;
  background: #090909;
}

.nose {
  position: absolute;
  top: 61rpx;
  left: 58rpx;
  width: 12rpx;
  height: 9rpx;
  border-radius: 50%;
  background: #f28b64;
}

.smile {
  position: absolute;
  right: 24rpx;
  bottom: 12rpx;
  width: 34rpx;
  height: 16rpx;
  border-bottom: 5rpx solid #090909;
  border-radius: 0 0 24rpx 24rpx;
}

.neck {
  position: absolute;
  top: 89rpx;
  left: 105rpx;
  width: 28rpx;
  height: 24rpx;
  background: #ffd8aa;
}

.body {
  position: absolute;
  top: 104rpx;
  left: 66rpx;
  width: 116rpx;
  height: 108rpx;
  overflow: hidden;
  border: 6rpx solid #090909;
  border-radius: 10rpx 18rpx 12rpx 12rpx;
  background: #f6fbf3;
  transform: rotate(-2deg);
}

.shirt-line {
  position: absolute;
  background: #75bad1;
  opacity: .78;
}

.shirt-line.v1 {
  top: 0;
  bottom: 0;
  left: 34rpx;
  width: 6rpx;
}

.shirt-line.v2 {
  top: 0;
  bottom: 0;
  right: 34rpx;
  width: 6rpx;
}

.shirt-line.h1,
.shirt-line.h2,
.shirt-line.h3 {
  right: 0;
  left: 0;
  height: 6rpx;
}

.shirt-line.h1 {
  top: 24rpx;
}

.shirt-line.h2 {
  top: 50rpx;
}

.shirt-line.h3 {
  top: 76rpx;
}

.arm,
.leg {
  position: absolute;
  transform-origin: top center;
}

.arm {
  z-index: 6;
  width: 34rpx;
  height: 96rpx;
  border: 6rpx solid #090909;
  border-radius: 20rpx;
  background: #f6fbf3;
}

.arm-back {
  top: 116rpx;
  left: 48rpx;
  transform: rotate(30deg);
  animation: armBack .74s ease-in-out infinite alternate;
}

.arm-front {
  top: 104rpx;
  right: 30rpx;
  transform: rotate(-54deg);
  animation: armFront .74s ease-in-out infinite alternate;
}

.hand {
  position: absolute;
  bottom: -22rpx;
  left: -4rpx;
  width: 36rpx;
  height: 36rpx;
  border: 6rpx solid #090909;
  border-radius: 50%;
  background: #ffd8aa;
}

.leg {
  top: 201rpx;
  width: 38rpx;
  height: 84rpx;
  border: 6rpx solid #090909;
  border-radius: 20rpx;
  background: #173a55;
}

.leg-back {
  left: 84rpx;
  transform: rotate(38deg);
  animation: legBack .74s ease-in-out infinite alternate;
}

.leg-front {
  right: 54rpx;
  transform: rotate(-38deg);
  animation: legFront .74s ease-in-out infinite alternate;
}

.shoe {
  position: absolute;
  right: -28rpx;
  bottom: -14rpx;
  width: 58rpx;
  height: 24rpx;
  border-radius: 24rpx;
  background: #050505;
}

.pillar-wrap {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr 1.34fr 1fr;
  height: 420rpx;
}

.pillar {
  position: relative;
  overflow: hidden;
}

.pillar::before {
  position: absolute;
  top: 0;
  right: -2rpx;
  left: -2rpx;
  height: 92rpx;
  background: #fff9ec;
  clip-path: polygon(0 0, 100% 0, 100% 68%, 50% 100%, 0 68%);
  content: "";
}

.pillar-left,
.pillar-right {
  background: linear-gradient(90deg, #ffe3dc 0%, #ffb5b9 64%, #ff9ea9 100%);
}

.pillar-mid {
  background: linear-gradient(90deg, #78e5e2 0%, #8ef2ef 55%, #66d3dd 100%);
}

.home-start {
  position: absolute;
  right: 178rpx;
  bottom: 276rpx;
  left: 178rpx;
  z-index: 12;
  height: 98rpx;
  border: 7rpx solid #060606;
  border-radius: 54rpx;
  color: #050505;
  background: rgba(255, 255, 245, 0.96);
  font-size: 40rpx;
  font-weight: 900;
  line-height: 84rpx;
  text-align: center;
  box-shadow: 0 9rpx 0 rgba(0, 0, 0, 0.12);
  animation: buttonPulse 1.2s ease-in-out infinite alternate;
}

.home-start.loading {
  color: #4a524e;
  animation: none;
}

.sound-toggle {
  position: absolute;
  top: calc(28rpx + env(safe-area-inset-top));
  right: 28rpx;
  z-index: 15;
  width: 72rpx;
  height: 72rpx;
  border: 4rpx solid rgba(0, 0, 0, 0.12);
  border-radius: 50%;
  color: #ffffff;
  background: rgba(0, 0, 0, 0.18);
  font-size: 38rpx;
  font-weight: 900;
  line-height: 64rpx;
  text-align: center;
}

.compliance {
  position: absolute;
  right: 28rpx;
  bottom: calc(22rpx + env(safe-area-inset-bottom));
  left: 28rpx;
  z-index: 11;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  color: rgba(22, 43, 31, 0.78);
  font-size: 21rpx;
  line-height: 1.42;
  text-align: center;
}

.advice-title {
  font-size: 25rpx;
  font-weight: 800;
}

.load-row {
  display: grid;
  grid-template-columns: 1fr 86rpx;
  gap: 14rpx;
  align-items: end;
  margin-top: 6rpx;
}

.load-track {
  position: relative;
  height: 30rpx;
  overflow: hidden;
  border: 4rpx solid #050505;
  background: #ffffff;
}

.load-fill {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(90deg, #222, #000);
  transition: width .18s ease;
}

.load-fill::after {
  position: absolute;
  top: 0;
  bottom: 0;
  left: -80rpx;
  width: 80rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.54), transparent);
  content: "";
  animation: loadShine 1s linear infinite;
}

.load-text {
  min-height: 28rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 22rpx;
  text-shadow: 0 2rpx 0 rgba(36, 86, 40, 0.2);
}

.age-badge {
  display: flex;
  width: 86rpx;
  height: 108rpx;
  flex-direction: column;
  justify-content: center;
  border: 4rpx solid #ffffff;
  border-radius: 8rpx;
  color: #ffffff;
  background: #69bb3c;
  box-shadow: 0 0 0 2rpx rgba(0, 0, 0, 0.42);
  text-align: center;
}

.age-main {
  font-size: 38rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.age-mid {
  font-size: 15rpx;
  font-weight: 800;
  line-height: 20rpx;
}

.age-small {
  font-size: 18rpx;
  font-weight: 800;
  line-height: 22rpx;
}

.skin-chosen {
  background: linear-gradient(145deg, #eef5e9, #fff8e8);
}

.skin-calm {
  background: linear-gradient(145deg, #e1f4dc, #f5fbef);
}

.skin-knight {
  color: #f5f7f3;
  background: linear-gradient(145deg, #101820, #25313a);
}

.skin-blue {
  background: linear-gradient(145deg, #eaf4ff, #eef5e9);
}

.skin-green {
  background: linear-gradient(145deg, #e7f7ee, #fbfcf4);
}

.skin-orange {
  background: linear-gradient(145deg, #fff2df, #eaf4ff);
}

.skin-aurora {
  background: linear-gradient(145deg, #e7fff7, #f4edff);
}

.skin-night {
  color: #f5f7f3;
  background: linear-gradient(145deg, #243447, #4b5f72);
}

.topbar {
  display: grid;
  grid-template-columns: 1fr 108rpx;
  gap: 18rpx;
  align-items: center;
  min-height: 92rpx;
  padding: 18rpx 18rpx 14rpx;
  border: 1rpx solid rgba(61, 85, 73, 0.12);
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.62);
  box-shadow: 0 10rpx 28rpx rgba(33, 50, 42, 0.06);
}

.rank-block {
  display: flex;
  min-width: 0;
  flex-direction: column;
}

.rank-title {
  display: block;
  overflow: hidden;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 42rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-tier {
  margin-top: 6rpx;
  color: #6f766f;
  font-size: 22rpx;
}

.timer {
  height: 72rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #2f5f50;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 72rpx;
  text-align: center;
}

.locked {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 120rpx;
  padding: 36rpx;
}

.locked-title {
  font-size: 38rpx;
  font-weight: 700;
}

.locked-copy {
  color: #6f766f;
  font-size: 28rpx;
  line-height: 1.7;
}

.game-shell {
  position: relative;
  min-height: calc(100vh - 160rpx);
}

.guide {
  position: absolute;
  top: 26rpx;
  left: 50%;
  z-index: 4;
  width: 560rpx;
  max-width: calc(100vw - 64rpx);
  padding: 16rpx 20rpx;
  transform: translateX(-50%);
  border-radius: 8rpx;
  color: #415349;
  background: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  text-align: center;
}

.meters {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  min-height: 760rpx;
  padding-top: 34rpx;
}

.meter-zone {
  display: flex;
  align-items: center;
  flex-direction: column;
  justify-content: center;
  position: relative;
  overflow: visible;
  min-width: 0;
  min-height: 744rpx;
  padding: 18rpx 8rpx 20rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(61, 85, 73, 0.1);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(234, 244, 236, 0.34));
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7), 0 16rpx 32rpx rgba(33, 50, 42, 0.06);
}

.dev-device,
.mood-device {
  position: relative;
  width: 318rpx;
  height: 500rpx;
}

.meter-effects {
  position: absolute;
  top: 120rpx;
  right: 0;
  bottom: 110rpx;
  left: 0;
  pointer-events: none;
  overflow: visible;
  z-index: 30;
}

.meter-effect {
  position: absolute;
  z-index: 31;
  min-width: 168rpx;
  padding: 18rpx 26rpx;
  border-radius: 999rpx;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1;
  opacity: 0;
  transform: translate(-50%, -50%);
  animation: floatScore 1s ease-out forwards;
  box-shadow: 0 18rpx 34rpx rgba(22, 30, 27, 0.3);
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.16);
  text-align: center;
  white-space: nowrap;
}

.meter-effect.gain {
  color: #f0fff5;
  background: linear-gradient(180deg, rgba(72, 224, 131, 0.98), rgba(29, 133, 74, 0.96));
  border: 4rpx solid rgba(198, 255, 220, 0.92);
}

.meter-effect.loss {
  color: #fff6f7;
  background: linear-gradient(180deg, rgba(255, 123, 141, 0.98), rgba(193, 56, 84, 0.96));
  border: 4rpx solid rgba(255, 217, 223, 0.9);
}

.meter-effect.bonus {
  color: #fff7d0;
  background: linear-gradient(180deg, rgba(255, 204, 73, 0.98), rgba(214, 134, 29, 0.96));
  border: 4rpx solid rgba(255, 240, 183, 0.9);
}

.progress-effects {
  left: 0;
  overflow: visible;
}

.mood-effects {
  right: 0;
  overflow: visible;
}

.progress-effects .meter-effect {
  border: 3rpx solid rgba(171, 255, 201, 0.55);
}

.mood-effects .meter-effect {
  border: 3rpx solid rgba(255, 207, 219, 0.55);
}

.zone-fx {
  display: none;
}

.zone-effects {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 40;
  pointer-events: none;
  overflow: visible;
}

.code-screen .zone-effects,
.mood-glass .zone-effects {
  overflow: visible;
}

.machine-tag {
  height: 42rpx;
  margin-bottom: 16rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  color: #e8fff1;
  background: #26342e;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 42rpx;
  letter-spacing: 0;
  box-shadow: 0 8rpx 0 rgba(38, 52, 46, 0.24);
}

.mood-tag {
  color: #fff4f6;
  background: #7e4152;
}

.dev-device {
  display: flex;
  align-items: center;
  flex-direction: column;
  justify-content: flex-start;
}

.value-axis {
  position: absolute;
  top: 64rpx;
  left: 0;
  z-index: 8;
  width: 38rpx;
  height: 386rpx;
  pointer-events: none;
}

.axis-top-meter {
  position: absolute;
  top: -42rpx;
  left: 5rpx;
  width: 24rpx;
  height: 58rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(195, 255, 212, 0.78);
  background: linear-gradient(180deg, #05b553 0%, #3fd96e 64%, #f0ffd3 100%);
  box-shadow: inset 0 6rpx 8rpx rgba(255, 255, 255, 0.22), 0 0 22rpx rgba(92, 255, 141, 0.5);
}

.axis-top-meter::before,
.axis-top-meter::after {
  position: absolute;
  right: 8rpx;
  left: 8rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: rgba(229, 255, 219, 0.88);
  content: "";
  box-shadow: 0 12rpx 0 rgba(229, 255, 219, 0.72), 0 24rpx 0 rgba(229, 255, 219, 0.55);
}

.axis-top-meter::before {
