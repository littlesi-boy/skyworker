.desk-scene {
  position: relative;
  height: 176rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: rgba(47, 95, 80, 0.1);
}

.desk-scene::before,
.desk-scene::after {
  position: absolute;
  content: "";
}

.desk-scene::before {
  z-index: 1;
  right: 0;
  bottom: 0;
  left: 0;
  height: 100%;
  background: radial-gradient(circle at 22% 20%, rgba(255, 255, 255, 0.42), transparent 24%), linear-gradient(145deg, rgba(236, 247, 228, 0.96), rgba(221, 239, 205, 0.92));
}

.desk-scene::after {
  z-index: 1;
  bottom: -16rpx;
  left: 50%;
  width: 180rpx;
  height: 150rpx;
  transform: translateX(-50%) rotate(8deg);
  border-radius: 90rpx 90rpx 0 0;
  background: rgba(255, 239, 196, 0.8);
  box-shadow: inset 0 0 0 4rpx rgba(156, 132, 86, 0.1);
}

.skin-calm .desk-scene::before {
  background:
    radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.48), transparent 24%),
    linear-gradient(145deg, #dff3d5 0%, #edf8e3 52%, #cceac6 100%);
}

.skin-calm .desk-scene::after {
  width: 210rpx;
  height: 156rpx;
  background: #eaf9cb;
  box-shadow:
    -138rpx 18rpx 0 -68rpx #62b66f,
    -112rpx 3rpx 0 -70rpx #3f9954,
    -88rpx 20rpx 0 -68rpx #75c87e,
    88rpx 10rpx 0 -70rpx #4fa763,
    116rpx 24rpx 0 -68rpx #6fbe78,
    142rpx 4rpx 0 -70rpx #3e9354,
    inset 0 0 0 4rpx rgba(82, 144, 64, 0.12);
}

.skin-knight .desk-scene {
  background: #111a22;
}

.skin-knight .desk-scene::before {
  background:
    repeating-linear-gradient(0deg, rgba(121, 216, 255, 0.12) 0rpx, rgba(121, 216, 255, 0.12) 2rpx, transparent 2rpx, transparent 32rpx),
    repeating-linear-gradient(90deg, rgba(121, 216, 255, 0.1) 0rpx, rgba(121, 216, 255, 0.1) 2rpx, transparent 2rpx, transparent 42rpx),
    linear-gradient(145deg, #111923, #202c36 64%, #0d141b);
}

.skin-knight .desk-scene::after {
  right: 18rpx;
  bottom: 18rpx;
  left: 18rpx;
  width: auto;
  height: 74rpx;
  transform: none;
  border-radius: 8rpx;
  background:
    repeating-linear-gradient(90deg, transparent 0rpx, transparent 29rpx, rgba(105, 218, 255, 0.2) 29rpx, rgba(105, 218, 255, 0.2) 32rpx),
    repeating-linear-gradient(0deg, transparent 0rpx, transparent 28rpx, rgba(105, 218, 255, 0.18) 28rpx, rgba(105, 218, 255, 0.18) 31rpx),
    linear-gradient(180deg, #27343e, #121b23);
  box-shadow: 0 0 22rpx rgba(88, 207, 255, 0.16), inset 0 0 0 2rpx rgba(105, 218, 255, 0.22);
}

