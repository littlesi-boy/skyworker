<view class="safe-page work-page skin-{{activeSkin.tone}} {{showHome ? 'home-active' : ''}}">
  <view class="welcome-toast" wx:if="{{welcomeToast}}">
    <view class="welcome-band"></view>
    <view class="welcome-copy">
      <text class="welcome-mark">✦</text>
      <text class="welcome-title">亲爱的天选打工人</text>
      <text class="welcome-text">欢迎来到天工一号</text>
    </view>
  </view>
  <block wx:if="{{showHome}}">
    <view class="home-scene">
      <view class="sun-panel">
        <text class="home-title">天工一号</text>
        <text class="home-title sub">码农大闯关</text>
      </view>
      <view class="sky-panel">
        <view class="cloud cloud-a"></view>
        <view class="cloud cloud-b"></view>
        <view class="grass grass-a"></view>
        <view class="grass grass-b"></view>
        <view class="grass grass-c"></view>
        <view class="rope-label work-label">工作</view>
        <view class="rope-label life-label">生活</view>
        <view class="balance-rope rope-one"></view>
        <view class="balance-rope rope-two"></view>
        <view class="rope-pin pin-left"></view>
        <view class="rope-pin pin-right"></view>

        <view class="runner">
          <view class="hair tuft-a"></view>
          <view class="hair tuft-b"></view>
          <view class="head">
            <view class="ear"></view>
            <view class="face">
              <view class="eye-glass left"></view>
              <view class="eye-glass right"></view>
              <view class="bridge"></view>
              <view class="nose"></view>
              <view class="smile"></view>
            </view>
          </view>
          <view class="neck"></view>
          <view class="body">
            <view class="shirt-line v1"></view>
            <view class="shirt-line v2"></view>
            <view class="shirt-line h1"></view>
            <view class="shirt-line h2"></view>
            <view class="shirt-line h3"></view>
          </view>
          <view class="arm arm-back"><view class="hand"></view></view>
          <view class="arm arm-front"><view class="hand"></view></view>
          <view class="leg leg-back"><view class="shoe"></view></view>
          <view class="leg leg-front"><view class="shoe"></view></view>
        </view>
      </view>
      <view class="pillar-wrap">
        <view class="pillar pillar-left"></view>
        <view class="pillar pillar-mid"></view>
        <view class="pillar pillar-right"></view>
      </view>
      <view class="home-start {{homeLoading ? 'loading' : ''}}">
        <text>{{homeLoading ? '加载中' : '进入游戏'}}</text>
      </view>
      <button class="sound-toggle" bindtap="toggleHomeBgm">
        <text>{{homeMuted ? '♪' : '♫'}}</text>
      </button>
      <view class="compliance">
        <text class="advice-title">健康游戏忠告</text>
        <text>抵制不良游戏，拒绝盗版游戏。注意自我保护，谨防受骗上当。</text>
        <text>适度游戏益脑，沉迷游戏伤身。合理安排时间，享受健康生活。</text>
        <text>著作权人：杭州斯滑工作室</text>
        <view class="load-row">
          <view class="load-track">
            <view class="load-fill" style="width: {{homeProgress}}%;"></view>
          </view>
          <view class="age-badge">
            <text class="age-main">8+</text>
            <text class="age-mid">CADPA</text>
            <text class="age-small">适龄提示</text>
          </view>
        </view>
        <text class="load-text">{{homeProgressText}} ({{homeProgress}}%)</text>
      </view>
    </view>
  </block>
  <block wx:else>
  <view class="topbar">
    <view class="rank-block">
      <text class="rank-title">{{rank.title}}</text>
      <text class="rank-tier">{{rank.tier}} · {{profile.totalScore}}/{{rank.threshold}}分</text>
    </view>
    <view class="timer">{{timeLeft}}s</view>
  </view>

  <view class="game-shell">
    <view class="guide" wx:if="{{showGuide}}">敲亮代码屏，照顾心态舱；任意一项归零就会崩盘</view>

    <view class="meters">
      <view class="meter-zone progress-zone" bindtap="tapProgress">
        <view class="machine-tag">开发终端</view>
        <view class="zone-fx progress-zone-fx"></view>
        <view class="dev-device">
          <view class="zone-effects progress-effects">
            <view wx:for="{{progressEffectList}}" wx:key="id" class="meter-effect {{item.cls}}" style="left: {{item.leftPx}}px; top: {{item.topPx}}px;">
              <text>{{item.text}}</text>
            </view>
          </view>
          <view class="value-axis progress-axis">
            <view class="axis-top-meter"></view>
            <view class="axis-line"></view>
            <view class="axis-thumb" style="bottom: {{progress}}%;"></view>
          </view>
          <view class="progress-gauge">
            <view class="progress-gauge-dot"></view>
            <view class="gauge-ticks"></view>
            <view class="progress-gauge-bar" style="width: {{progress}}%;"></view>
          </view>
          <view class="code-screen">
            <view class="scan-line"></view>
            <view class="code-fill" style="height: {{progress}}%;">
              <text class="code-rain rain-a">0101</text>
              <text class="code-rain rain-b">merge</text>
              <text class="code-rain rain-c">npm run build</text>
              <text class="code-line">const bug = fix();</text>
              <text class="code-line short">git push origin</text>
              <text class="code-line">deploy.status = green</text>
              <text class="code-line dim">while(task) focus++</text>
              <text class="code-line">progress += commit</text>
            </view>
            <view class="screen-glare"></view>
            <view class="perfect-line device-line"></view>
            <view class="freeze-cover progress-freeze-cover" wx:if="{{freezeActive}}">
              <view class="ice-crack crack-a"></view>
              <view class="ice-crack crack-b"></view>
              <view class="ice-snow snow-a">❄</view>
              <view class="ice-snow snow-b">✦</view>
              <view class="ice-snow snow-c">❄</view>
              <text class="freeze-label">冻结</text>
            </view>
          </view>
        </view>
        <text class="meter-value">{{progressText}}%</text>
        <text class="meter-title">开发进度</text>
        <text class="meter-note">改bug / 联调 / 线上排障</text>
      </view>

      <view class="meter-zone mood-zone" bindtap="tapMood">
        <view class="machine-tag mood-tag">心态反应炉</view>
        <view class="zone-fx mood-zone-fx"></view>
        <view class="mood-device mood-{{moodLevel}}">
          <view class="zone-effects mood-effects">
            <view wx:for="{{moodEffectList}}" wx:key="id" class="meter-effect {{item.cls}}" style="left: {{item.leftPx}}px; top: {{item.topPx}}px;">
              <text>{{item.text}}</text>
            </view>
          </view>
          <view class="value-axis mood-axis">
            <view class="axis-top-meter"></view>
            <view class="axis-line"></view>
            <view class="axis-thumb" style="bottom: {{mood}}%;"></view>
          </view>
          <view class="pressure-gauge">
            <view class="gauge-dot"></view>
            <view class="gauge-ticks"></view>
            <view class="gauge-bar" style="width: {{mood}}%;"></view>
          </view>
          <view class="mood-glass">
            <view class="heart-stack" style="height: {{mood}}%;">
              <view class="heart-bubble heart-a"></view>
              <view class="heart-bubble heart-b"></view>
              <view class="heart-bubble heart-c"></view>
              <view class="heart-bubble heart-d"></view>
              <view class="heart-bubble heart-e"></view>
              <view class="heart-bubble heart-f"></view>
              <view class="heart-bubble heart-g"></view>
              <view class="heart-bubble heart-h"></view>
              <view class="mood-bubble bubble-a"></view>
              <view class="mood-bubble bubble-b"></view>
              <view class="mood-bubble bubble-c"></view>
              <view class="mood-bubble bubble-d"></view>
            </view>
            <view class="main-heart">
              <view class="heart-shape"></view>
              <view class="heart-eye left-eye"></view>
              <view class="heart-eye right-eye"></view>
              <view class="heart-mouth"></view>
            </view>
            <view class="mood-mark left"></view>
            <view class="mood-mark right"></view>
            <view class="perfect-line mood-line"></view>
            <view class="freeze-cover mood-freeze-cover" wx:if="{{freezeActive}}">
              <view class="ice-crack crack-a"></view>
              <view class="ice-crack crack-b"></view>
              <view class="ice-snow snow-a">❄</view>
              <view class="ice-snow snow-b">✦</view>
              <view class="ice-snow snow-c">❄</view>
              <text class="freeze-label">冻结</text>
            </view>
          </view>
          <view class="mood-label">心态舱</view>
        </view>
        <text class="meter-value">{{moodText}}%</text>
        <text class="meter-title">心态指数</text>
        <text class="meter-note">呼吸 / 喝水 / 稳住</text>
      </view>
    </view>

    <view class="event-toast" wx:if="{{eventToast}}">
      <view class="robot-float toast-robot">
        <image class="robot-float-img" src="/assets/img/robot.png" mode="aspectFit"></image>
        <view class="robot-eye left"></view>
        <view class="robot-eye right"></view>
      </view>
      <text class="event-title">{{eventToast.title}}</text>
      <text>{{eventToast.desc}}</text>
    </view>

    <view class="freeze-toast" wx:if="{{freezeToast}}">
      <view class="robot-float toast-robot">
        <image class="robot-float-img" src="/assets/img/robot.png" mode="aspectFit"></image>
        <view class="robot-eye left"></view>
        <view class="robot-eye right"></view>
      </view>
      <text class="freeze-toast-mark">❄</text>
      <view class="freeze-toast-copy">
        <text class="freeze-toast-title">{{freezeToast.title}}</text>
        <text>{{freezeToast.desc}}</text>
      </view>
      <text class="freeze-toast-mark">❄</text>
    </view>

    <view class="overtime-pop soft-card" wx:if="{{overtimeModal}}">
      <view class="robot-float">
        <image class="robot-float-img" src="/assets/img/robot.png" mode="aspectFit"></image>
        <view class="robot-eye left"></view>
        <view class="robot-eye right"></view>
      </view>
      <text class="overtime-title">【{{overtimeModal.title}}】</text>
      <text class="overtime-desc">{{overtimeModal.desc}}</text>
      <button class="primary-btn tiny" bindtap="acceptOvertime">{{overtimeModal.accept}}</button>
      <text class="overtime-note">{{overtimeModal.acceptNote}}</text>
      <button class="ghost-btn tiny" bindtap="rejectOvertime">{{overtimeModal.reject}}</button>
    </view>

    <view class="workspace soft-card">
      <view class="desk-scene">
        <view class="monitor">
          <view class="screen-line short"></view>
          <view class="screen-line"></view>
          <view class="screen-line dim"></view>
        </view>
        <view class="desk"></view>
        <view class="badge" wx:if="{{profile.rankIndex === maxRankIndex}}">毕业</view>
        <button class="game-control {{status === 'running' && !paused ? 'playing' : ''}}" bindtap="controlGame">
          <text class="control-icon">{{status === 'running' && !paused ? 'Ⅱ' : '▶'}}</text>
          <text class="control-text">{{status === 'running' && !paused ? '暂停摸鱼' : '开始上工'}}</text>
        </button>
      </view>
      <text class="workspace-title">{{activeSkin.name}}</text>
      <text class="workspace-desc">{{rank.workspace}}</text>
    </view>

    <view class="item-dock-wrap">
      <scroll-view class="item-dock" scroll-x scroll-with-animation scroll-left="{{itemDockScrollLeft}}" enhanced show-scrollbar="{{false}}" bindtouchstart="onItemDockTouchStart" bindtouchend="onItemDockTouchEnd">
        <view class="item-track">
          <button class="item-btn" wx:for="{{visibleItemDock}}" wx:key="id" data-id="{{item.id}}" bindtap="useItem">
            <text class="item-icon">{{item.icon}}</text>
            <text class="item-count">x{{item.count}}</text>
            <text class="item-name">{{item.shortName}}</text>
          </button>
        </view>
      </scroll-view>
      <button class="item-scroll-btn {{itemDockScrolled ? 'left' : 'right'}}" bindtap="toggleItemDockScroll">
        <text>{{itemDockScrolled ? '‹' : '›'}}</text>
      </button>
    </view>
  </view>

  <view class="fail-slam {{failOverlay.reason}}" wx:if="{{failOverlay}}">
    <view class="slam-line"></view>
    <text class="slam-title">{{failOverlay.title}}</text>
    <text class="slam-copy">本局强制结束，先把自己捞回来。</text>
  </view>

  <view class="modal-mask" wx:if="{{resultModal}}">
    <view class="result-card soft-card {{resultModal.type}}">
      <view class="robot-float">
        <image class="robot-float-img" src="/assets/img/robot.png" mode="aspectFit"></image>
        <view class="robot-eye left"></view>
        <view class="robot-eye right"></view>
      </view>
      <view class="mascot">{{resultModal.type === 'success' ? '✦' : '☁'}}</view>
      <text class="result-title">{{resultModal.title}}</text>
      <text class="result-copy">{{resultModal.copy}}</text>
      <view class="reward-list" wx:if="{{resultModal.rewards.length}}">
        <text wx:for="{{resultModal.rewards}}" wx:key="*this" class="reward-chip">{{item}}</text>
      </view>
      <view class="result-actions" wx:if="{{resultModal.type === 'fail' && resultModal.bonusBean}}">
        <button class="primary-btn" bindtap="claimFailureBean">确认领取</button>
        <button class="ghost-btn" bindtap="closeResult">暂不领取</button>
      </view>
      <view class="result-actions" wx:elif="{{resultModal.type === 'fail'}}">
        <button class="primary-btn" bindtap="reviveByAd">答题挑战，原地复活</button>
        <button class="ghost-btn" bindtap="closeResult">关闭退出</button>
      </view>
      <button class="ghost-btn" bindtap="closeResult">{{resultModal.type === 'success' ? '收下奖励' : '关闭退出'}}</button>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{reviveExamModal}}">
    <view class="exam-card soft-card">
      <view class="robot-float">
        <image class="robot-float-img" src="/assets/img/robot.png" mode="aspectFit"></image>
        <view class="robot-eye left"></view>
        <view class="robot-eye right"></view>
      </view>
      <view class="mascot">?</view>
      <text class="result-title">复活答题</text>
      <text class="result-copy">开发题和心态题各答对 1 题即可原地复活。</text>
      <view class="exam-list">
        <view class="exam-question" wx:for="{{reviveExamModal.questions}}" wx:for-index="qIndex" wx:key="id">
          <text class="exam-tag">{{item.label}}</text>
          <text class="exam-title">{{qIndex + 1}}. {{item.question}}</text>
          <view class="exam-options" wx:if="{{item.type === 'choice'}}">
            <button
              class="exam-option {{reviveExamModal.answers[qIndex] === option.key ? 'selected' : ''}}"
              wx:for="{{item.displayOptions}}"
              wx:for-item="option"
              wx:key="key"
              data-index="{{qIndex}}"
              data-value="{{option.key}}"
              bindtap="chooseExamAnswer"
            >{{option.label}}</button>
          </view>
          <input
            wx:else
            class="exam-input"
            placeholder="输入答案"
            data-index="{{qIndex}}"
            value="{{reviveExamModal.answers[qIndex] || ''}}"
            bindinput="inputExamAnswer"
          />
        </view>
      </view>
      <text class="exam-error" wx:if="{{reviveExamModal.error}}">{{reviveExamModal.error}}</text>
      <view class="result-actions">
        <button class="primary-btn" bindtap="submitReviveExam">提交复活</button>
        <button class="ghost-btn" bindtap="closeResult">放弃复活</button>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{checkInModal}}">
    <view class="result-card soft-card success">
      <view class="robot-float">
        <image class="robot-float-img" src="/assets/img/robot.png" mode="aspectFit"></image>
        <view class="robot-eye left"></view>
        <view class="robot-eye right"></view>
      </view>
      <view class="mascot">✓</view>
      <text class="result-title">今日上工自动打卡成功</text>
      <text class="result-copy">{{checkInModal.copy}}</text>
      <view class="reward-list" wx:if="{{checkInModal.reward}}">
        <text class="reward-chip">{{checkInModal.reward}}</text>
      </view>
      <button class="primary-btn" bindtap="closeCheckIn">知道了</button>
    </view>
  </view>
  </block>
</view>
