.profile-page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(145deg, #eef5e9, #f8faf0);
}

.skin-blue {
  background: linear-gradient(145deg, #eaf4ff, #eef5e9);
}

.skin-green {
  background: linear-gradient(145deg, #e7f7ee, #fbfcf4);
}

.skin-orange {
  background: linear-gradient(145deg, #fff2df, #eaf4ff);
}

.skin-aurora {
  background: linear-gradient(145deg, #e7fff7, #f4edff);
}

.skin-night {
  color: #f5f7f3;
  background: linear-gradient(145deg, #243447, #4b5f72);
}

.profile-panel {
  display: grid;
  grid-template-columns: 132rpx 1fr;
  gap: 24rpx;
  align-items: center;
  padding: 24rpx;
}

.avatar-button {
  width: 132rpx;
  height: 132rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: rgba(47, 95, 80, 0.12);
}

.avatar {
  width: 132rpx;
  height: 132rpx;
}

.placeholder {
  color: #2f5f50;
  font-size: 58rpx;
  font-weight: 800;
  line-height: 132rpx;
  text-align: center;
}

.profile-fields {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 14rpx;
}

.nickname-input,
.motto-input {
  width: 100%;
  height: 58rpx;
  padding: 0 16rpx;
  border-radius: 8rpx;
  color: #27312d;
  background: rgba(47, 95, 80, 0.08);
}

.nickname-input {
  font-size: 34rpx;
  font-weight: 800;
}

.motto-input {
  color: #6f766f;
  font-size: 26rpx;
}

.list-panel {
  margin-top: 18rpx;
  padding: 0 24rpx;
}

.info-row {
  display: flex;
  min-height: 96rpx;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  border-bottom: 1rpx solid rgba(61, 85, 73, 0.1);
}

.info-row:last-child {
  border-bottom: 0;
}

.row-label {
  color: #27312d;
  font-size: 28rpx;
  font-weight: 700;
}

.row-value {
  max-width: 430rpx;
  overflow: hidden;
  color: #6f766f;
  font-size: 26rpx;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.danger-row .row-label {
  color: #8f3a3a;
}

.mini {
  min-width: 140rpx;
  min-height: 58rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
}

.modal-mask {
  position: fixed;
  z-index: 20;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(31, 39, 35, 0.42);
}

.result-card {
  position: relative;
  display: flex;
  width: 100%;
  max-width: 640rpx;
  flex-direction: column;
  gap: 22rpx;
  padding: 58rpx 32rpx 32rpx;
  color: #27312d;
  text-align: center;
}

.mascot {
  position: absolute;
  top: -38rpx;
  left: 50%;
  width: 86rpx;
  height: 86rpx;
  transform: translateX(-50%);
  border-radius: 50%;
  color: #ffffff;
  background: #2f5f50;
  font-size: 44rpx;
  line-height: 86rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: 800;
}

.result-copy {
  color: #5f6962;
  font-size: 28rpx;
  line-height: 1.65;
}

.reward-chip {
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  color: #2f5f50;
  background: rgba(47, 95, 80, 0.1);
  font-size: 22rpx;
}
