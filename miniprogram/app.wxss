page {
  min-height: 100%;
  color: #27312d;
  background: #f5f7f3;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  line-height: 1.2;
  border-radius: 0;
  background: transparent;
}

button::after {
  border: 0;
}

.safe-page {
  min-height: 100vh;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
}

.soft-card {
  border: 1rpx solid rgba(61, 85, 73, 0.12);
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 12rpx 34rpx rgba(33, 50, 42, 0.06);
}

.primary-btn,
.ghost-btn,
.danger-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.primary-btn {
  color: #ffffff;
  background: #2f5f50;
}

.ghost-btn {
  color: #2f5f50;
  border: 1rpx solid rgba(47, 95, 80, 0.28);
  background: rgba(255, 255, 255, 0.7);
}

.danger-btn {
  color: #8f3a3a;
  border: 1rpx solid rgba(143, 58, 58, 0.28);
  background: rgba(255, 255, 255, 0.7);
}

.muted {
  color: #7a827b;
}
